# Inspira — environment example
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
# Syntax: KEY=value — no quotes needed for simple strings.
# Lines starting with # are comments. Blank lines are ignored.
#
# Local dev: the backend reads this file automatically via _env_bootstrap.py.
# Docker Compose: pass via `env_file: .env` (already wired in docker-compose.yml).
# Production: inject via your deploy platform's secret manager — do NOT commit
# a populated .env to source control.

# ============================================================================
# REQUIRED IN PRODUCTION — the app will refuse to start without these when
# ENVIRONMENT=production
# ============================================================================

# Runtime environment. Gates the production startup assertions.
# Values: development (default) | production
ENVIRONMENT=development

# Signs itsdangerous session cookies. Must be 48+ random bytes in production.
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Dev fallback "inspira-dev-only-change-me" is rejected in production.
INSPIRA_SESSION_SECRET=REPLACE_ME

# Comma-separated allowed CORS origins. Required in production.
# Example: https://tryinspira.com,https://www.tryinspira.com
# Leave unset in local dev (all origins allowed).
# INSPIRA_ALLOWED_ORIGINS=

# Set to "true" in production so session cookies require HTTPS.
# Leave "false" for local HTTP dev.
INSPIRA_COOKIE_SECURE=false

# ============================================================================
# LLM PROVIDERS
# ============================================================================

# OpenAI — required for the planner agent, canvas-composer router, outline,
# plan summary, and deduplication. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_ME

# Anthropic — Claude fallback provider. Optional; if unset the claude adapter
# is disabled and OpenAI is used exclusively.
# ANTHROPIC_API_KEY=

# Override the default model used by the suggestions agent (default: gpt-4o-mini).
# INSPIRA_SUGGESTIONS_MODEL=gpt-4o-mini

# ============================================================================
# DATABASE
# ============================================================================

# Database connection URL. Defaults to SQLite at PLANNING_STUDIO_STORAGE_ROOT/db.sqlite3.
# For production Postgres: postgresql+psycopg://user:pass@host:5432/dbname
# DATABASE_URL=

# ============================================================================
# SERVICE BIND / NETWORK
# ============================================================================

# Host and port the backend uvicorn process listens on.
# Default: 127.0.0.1:4174 (localhost only). Docker sets HOST=0.0.0.0.
# PLANNING_STUDIO_HOST=127.0.0.1
# PLANNING_STUDIO_PORT=4174

# Root directory for SQLite database and file artifacts. Defaults to
# ./local/data (relative to the services/ package parent).
# PLANNING_STUDIO_STORAGE_ROOT=./local/data

# Uvicorn log level. Values: critical | error | warning | info (default) | debug | trace
# LOG_LEVEL=info

# Set to "true" to enable uvicorn auto-reload on code changes (dev only).
# UVICORN_RELOAD=false

# ============================================================================
# AUTH
# ============================================================================

# Google OAuth — NOT IMPLEMENTED in this build. The /api/auth/google/*
# endpoints return 501 even when this is set; email/password auth is the
# supported sign-in path.
# GOOGLE_OAUTH_CLIENT_ID=

# Public base URL of your frontend. Used to build share links, password-reset
# and other transactional-email URLs, OAuth redirects, and billing links.
# INSPIRA_APP_BASE_URL is preferred; INSPIRA_FRONTEND_URL is a legacy alias.
# Falls back to the request Origin header, then http://localhost:5173.
# INSPIRA_APP_BASE_URL=
# INSPIRA_FRONTEND_URL=

# Account email granted access to GET /api/admin/metrics. When unset, the
# admin metrics surface is disabled entirely.
# INSPIRA_ADMIN_EMAIL=

# From-identity for outgoing email, e.g. "Inspira <hello@yourdomain.com>".
# Defaults to "Inspira <hello@example.com>" — set this before enabling a
# real email provider.
# INSPIRA_EMAIL_FROM=

# OPTIONAL: regex of cross-site preview origins (e.g. per-PR preview deploys)
# that should receive SameSite=None session cookies. Disabled when unset —
# only set this to a pattern whose entire match space you control.
# INSPIRA_PREVIEW_ORIGIN_REGEX=

# ============================================================================
# RATE LIMITING (slowapi)
# ============================================================================

# Global per-IP request rate limit for all API routes. Format: N/period
# where period is second | minute | hour | day. Default: 120/minute.
# Client-error endpoint has its own stricter 30/minute cap applied on top.
# INSPIRA_RATE_LIMIT=120/minute

# ============================================================================
# PER-USER QUOTAS
# ============================================================================

# Maximum combined prompt+completion tokens a single user may consume per day.
# Non-positive value disables the gate (useful for dev/test).
# Default: 200000
# INSPIRA_USER_DAILY_TOKEN_BUDGET=200000

# Maximum outbound URL fetches (proxy endpoint) per user per day.
# Non-positive value disables the gate. Default: 200
# INSPIRA_USER_DAILY_URL_FETCH_CAP=200

# ============================================================================
# BILLING (Stripe) — all optional; omit entirely to use the Noop provider
# ============================================================================

# Stripe secret key. When set, real Stripe billing is activated automatically.
# Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=

# Stripe webhook signing secret. Required when STRIPE_SECRET_KEY is set.
# Get from the Stripe dashboard → Webhooks → your endpoint → Signing secret.
# STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each paid plan (monthly + annual). Create prices in
# the Stripe dashboard.
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_TEAM=
# STRIPE_PRICE_ID_PRO_ANNUAL=
# STRIPE_PRICE_ID_TEAM_ANNUAL=

# ============================================================================
# EMAIL
# ============================================================================

# Email provider. Values: resend | postmark | loops | (unset = no email)
# EMAIL_PROVIDER=

# Resend — https://resend.com
# RESEND_API_KEY=

# Postmark — https://postmarkapp.com
# POSTMARK_API_TOKEN=

# Loops — https://loops.so (used for transactional + marketing flows)
# LOOPS_API_KEY=
# LOOPS_TEMPLATE_IDS=   # JSON map of template name → template ID

# ============================================================================
# ERROR TRACKING (Sentry) — all optional; omit entirely to disable
# ============================================================================

# Backend Sentry DSN. When set, FastAPI route errors are reported to Sentry.
# Create a "Python / FastAPI" project at https://sentry.io and copy its DSN.
# SENTRY_DSN_BACKEND=

# Sentry performance tracing sample rate (0.0–1.0). Default: 0.1 (10%).
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# FRONTEND BUILD (Vite — baked in at build time, not readable at runtime)
# ============================================================================

# Backend API base URL inlined by Vite. Override at Docker build time via
# --build-arg VITE_INSPIRA_API_URL=... or in the frontend's .env.local.
# Default in the app bundle: http://127.0.0.1:4174
# VITE_INSPIRA_API_URL=http://127.0.0.1:4174

# Frontend Sentry DSN. Optional — when set, browser errors are reported to
# Sentry via @sentry/react.  Create a "JavaScript / React" project at
# https://sentry.io and copy its DSN.  Leave unset in local dev (no-op).
# VITE_SENTRY_DSN=

# ============================================================================
# DEV / SEED FLAGS
# ============================================================================

# Force-seed the legacy v1 demo project on startup. Off by default in prod.
# INSPIRA_SEED_V1_DEMO=false
