{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Planning Studio",
  "version": "0.1.0",
  "identifier": "com.jhoalens.planningstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4175",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Planning Studio",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
